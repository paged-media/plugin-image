{
  "name": "@paged-media/image-glue",
  "private": false,
  "version": "0.0.1-canary.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./decode-worker": "./src/decode-worker.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "tsup src/index.ts src/decode-worker.ts --format esm --dts --out-dir dist --clean",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@paged-media/image-manifest": "workspace:*",
    "@paged-media/plugin-api": "canary",
    "@paged-media/plugin-sdk": "canary"
  },
  "peerDependencies": {
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "canary",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./decode-worker": {
        "types": "./dist/decode-worker.d.ts",
        "default": "./dist/decode-worker.js"
      }
    }
  }
}
